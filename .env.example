# --- Site configuration ---
# Required in production: canonical URL for metadata and OG tags. Must start with https://.
NEXT_PUBLIC_SITE_URL=
# Optional: Google Analytics 4 measurement ID (format: G-XXXXXXXXXX). If unset, no analytics load.
NEXT_PUBLIC_GA_ID=
# Optional: external application portal URL (e.g. FACTS / RenWeb). If unset, a default RenWeb URL is used in code.
NEXT_PUBLIC_APPLY_URL=
