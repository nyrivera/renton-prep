DATABASE_URL=

# --- /api/score endpoint ---
# Required: Bearer token clients must send in Authorization header.
SCORING_API_KEY=
# Required: OpenAI secret key for scoring.
OPENAI_API_KEY=
# Optional: OpenAI model to use for scoring (defaults to gpt-4o).
OPENAI_SCORE_MODEL=

# --- Site configuration ---
# Required in production: canonical URL for metadata and OG tags. Must start with https://.
NEXT_PUBLIC_SITE_URL=
# Optional: Google Analytics 4 measurement ID (format: G-XXXXXXXXXX). If unset, no analytics load.
NEXT_PUBLIC_GA_ID=
# Optional: external application portal URL (e.g. FACTS). If unset, Apply links to /admissions.
NEXT_PUBLIC_APPLY_URL=https://sis.factsmgt.com/admissions-parent/home?districtCode=rpcs-wa&memberId=481&path=%252Foa%252Findex.cfm&sessionCode=anonymouspath
